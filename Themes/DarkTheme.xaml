<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Color x:Key="PrimaryBackground">#FF1A1A1A</Color>
    <Color x:Key="SecondaryBackground">#FF202020</Color>
    <Color x:Key="CardBackground">#FF2A2A2A</Color>
    <Color x:Key="PrimaryText">#FFFAFAFA</Color>
    <Color x:Key="SecondaryText">#FFB0B0B0</Color>
    <Color x:Key="AccentColor">#FF8B83FF</Color>
    <Color x:Key="AccentHover">#FFA09AFF</Color>
    <Color x:Key="BorderColor">#FF3A3A3A</Color>
    <Color x:Key="ShadowColor">#40000000</Color>
    <Color x:Key="CardSelectedBackground">#FF2E2B45</Color>
    <Color x:Key="PresetBackground">#FF2D2D2D</Color>
    <Color x:Key="PresetHover">#FF383838</Color>
    <Color x:Key="CancelButtonBackground">#FFFF6B6B</Color>
    <Color x:Key="CancelButtonHover">#FFFF8585</Color>
    <Color x:Key="ToggleTrack">#FF4A4A4A</Color>
    <Color x:Key="ToggleThumb">#FFFFFFFF</Color>
    <Color x:Key="NotificationBackground">#FF2A2A2A</Color>

    <SolidColorBrush x:Key="PrimaryBackgroundBrush" Color="{StaticResource PrimaryBackground}"/>
    <SolidColorBrush x:Key="SecondaryBackgroundBrush" Color="{StaticResource SecondaryBackground}"/>
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="{StaticResource CardBackground}"/>
    <SolidColorBrush x:Key="PrimaryTextBrush" Color="{StaticResource PrimaryText}"/>
    <SolidColorBrush x:Key="SecondaryTextBrush" Color="{StaticResource SecondaryText}"/>
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="AccentHoverBrush" Color="{StaticResource AccentHover}"/>
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}"/>
    <SolidColorBrush x:Key="CardSelectedBrush" Color="{StaticResource CardSelectedBackground}"/>
    <SolidColorBrush x:Key="PresetBackgroundBrush" Color="{StaticResource PresetBackground}"/>
    <SolidColorBrush x:Key="PresetHoverBrush" Color="{StaticResource PresetHover}"/>
    <SolidColorBrush x:Key="CancelButtonBrush" Color="{StaticResource CancelButtonBackground}"/>
    <SolidColorBrush x:Key="CancelButtonHoverBrush" Color="{StaticResource CancelButtonHover}"/>
    <SolidColorBrush x:Key="ToggleTrackBrush" Color="{StaticResource ToggleTrack}"/>
    <SolidColorBrush x:Key="ToggleThumbBrush" Color="{StaticResource ToggleThumb}"/>
    <SolidColorBrush x:Key="NotificationBackgroundBrush" Color="{StaticResource NotificationBackground}"/>

</ResourceDictionary>
